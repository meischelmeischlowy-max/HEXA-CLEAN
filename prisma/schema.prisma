generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum CustomerType {
  PRIVATE
  COMPANY
}

enum SessionStatus {
  ACTIVE
  COMPLETED
  ABANDONED
  EXPIRED
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
  OWNER
}

enum ServiceType {
  REINIGUNG
  HAUSWARTUNG
  KLEINREPARATUREN
  UMZUGSREINIGUNG
  FENSTERREINIGUNG
  WOHNUNGSABGABE
  OTHER
}

enum OrderStatus {
  NEW
  IN_PROGRESS
  WAITING_FOR_CUSTOMER
  CONFIRMED
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum EstimateStatus {
  DRAFT
  AI_REVIEW
  NEEDS_PHOTOS
  NEEDS_HUMAN_REVIEW
  READY_TO_SEND
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELLED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  TWINT
  CARD
  OTHER
}

enum NotificationChannel {
  EMAIL
  WHATSAPP
  SMS
  PUSH
  SYSTEM
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

enum AvailabilitySlotStatus {
  AVAILABLE
  BOOKED
  BLOCKED
}

enum AttachmentType {
  PHOTO
  DOCUMENT
  INVOICE
  QUOTE
  OTHER
}

enum ServiceCatalogCategory {
  REINIGUNG
  HAUSWARTUNG
  KLEINREPARATUREN
  UMZUGSREINIGUNG
  FENSTERREINIGUNG
  WOHNUNGSABGABE
  SPEZIALREINIGUNG
  OTHER
}

enum ServiceCatalogUnit {
  FLAT
  HOUR
  M2
  ROOM
  WINDOW
  PIECE
  KM
  CUSTOM
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  SYSTEM
  AI
}

model Customer {
  id   String       @id @default(uuid()) @db.Uuid
  type CustomerType @default(PRIVATE)

  firstName   String?
  lastName    String?
  companyName String?

  email String?
  phone String?

  street  String?
  zipCode String?
  city    String?
  country String  @default("CH")

  notes String?

  sessions         Session[]
  messages         ConversationMessage[]
  orders           Order[]
  estimates        Estimate[]
  quotes           Quote[]
  invoices         Invoice[]
  notifications    Notification[]
  attachments      Attachment[]
  auditLogs        AuditLog[]
  publicOfferLinks PublicOfferLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([phone])
  @@index([city])
  @@map("customers")
}

model Session {
  id     String        @id @default(uuid()) @db.Uuid
  status SessionStatus @default(ACTIVE)

  customerId String?   @db.Uuid
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  source   String?
  metadata Json?

  messages      ConversationMessage[]
  orders        Order[]
  estimates     Estimate[]
  quotes        Quote[]
  notifications Notification[]
  attachments   Attachment[]
  auditLogs     AuditLog[]

  startedAt DateTime  @default(now())
  endedAt   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([startedAt])
  @@map("sessions")
}

model ConversationMessage {
  id String @id @default(uuid()) @db.Uuid

  sessionId String  @db.Uuid
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  customerId String?   @db.Uuid
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  role     MessageRole
  content  String
  metadata Json?

  createdAt DateTime @default(now())

  @@index([sessionId, createdAt])
  @@index([customerId])
  @@map("conversation_messages")
}

model Order {
  id          String @id @default(uuid()) @db.Uuid
  orderNumber String @unique

  customerId String   @db.Uuid
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)

  sessionId String?  @db.Uuid
  session   Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  serviceType ServiceType
  title       String?
  description String?

  status OrderStatus @default(NEW)

  estimatedPrice Decimal? @db.Decimal(10, 2)
  finalPrice     Decimal? @db.Decimal(10, 2)
  currency       String   @default("CHF")

  serviceStreet  String?
  serviceZipCode String?
  serviceCity    String?
  serviceCountry String? @default("CH")

  preferredDate  DateTime?
  scheduledStart DateTime?
  scheduledEnd   DateTime?

  notesCustomer String?
  notesInternal String?

  estimates        Estimate[]
  quotes           Quote[]
  invoices         Invoice[]
  payments         Payment[]
  notifications    Notification[]
  attachments      Attachment[]
  auditLogs        AuditLog[]
  availabilitySlot AvailabilitySlot?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([sessionId])
  @@index([status])
  @@index([serviceType])
  @@index([scheduledStart])
  @@map("orders")
}

model AvailabilitySlot {
  id String @id @default(uuid()) @db.Uuid

  tenantKey String @default("hexa-clean")

  startAt DateTime
  endAt   DateTime

  status AvailabilitySlotStatus @default(AVAILABLE)

  orderId String? @unique @db.Uuid
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantKey, startAt, endAt])
  @@index([tenantKey])
  @@index([status])
  @@index([startAt])
  @@index([endAt])
  @@index([tenantKey, status, startAt])
  @@map("availability_slots")
}

model Estimate {
  id             String @id @default(uuid()) @db.Uuid
  estimateNumber String @unique

  tenantKey String @default("hexa-clean")

  customerId String   @db.Uuid
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)

  orderId String? @db.Uuid
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  sessionId String?  @db.Uuid
  session   Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  status EstimateStatus @default(DRAFT)
  source String?

  title       String?
  description String?

  serviceStreet  String?
  serviceZipCode String?
  serviceCity    String?
  serviceCountry String? @default("CH")

  preferredDate DateTime?

  subtotal       Decimal @default(0) @db.Decimal(10, 2)
  riskMultiplier Decimal @default(1.00) @db.Decimal(5, 2)
  riskAmount     Decimal @default(0) @db.Decimal(10, 2)
  travelFee      Decimal @default(0) @db.Decimal(10, 2)
  materialFee    Decimal @default(0) @db.Decimal(10, 2)
  discountAmount Decimal @default(0) @db.Decimal(10, 2)
  total          Decimal @default(0) @db.Decimal(10, 2)
  currency       String  @default("CHF")

  aiMinTotal Decimal? @db.Decimal(10, 2)
  aiMaxTotal Decimal? @db.Decimal(10, 2)
  aiNotes    String?

  notesCustomer String?
  notesInternal String?

  validUntil DateTime?
  sentAt     DateTime?
  acceptedAt DateTime?
  rejectedAt DateTime?

  items         EstimateItem[]
  notifications Notification[]
  attachments   Attachment[]
  auditLogs     AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantKey])
  @@index([customerId])
  @@index([orderId])
  @@index([sessionId])
  @@index([status])
  @@index([createdAt])
  @@map("estimates")
}

model EstimateItem {
  id String @id @default(uuid()) @db.Uuid

  estimateId String   @db.Uuid
  estimate   Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  serviceCatalogItemId String?             @db.Uuid
  serviceCatalogItem   ServiceCatalogItem? @relation(fields: [serviceCatalogItemId], references: [id], onDelete: SetNull)

  name        String
  description String?

  category ServiceCatalogCategory?
  unit     ServiceCatalogUnit      @default(FLAT)

  quantity       Decimal @default(1.00) @db.Decimal(10, 2)
  unitPrice      Decimal @default(0) @db.Decimal(10, 2)
  subtotal       Decimal @default(0) @db.Decimal(10, 2)
  riskMultiplier Decimal @default(1.00) @db.Decimal(5, 2)
  riskAmount     Decimal @default(0) @db.Decimal(10, 2)
  discountAmount Decimal @default(0) @db.Decimal(10, 2)
  total          Decimal @default(0) @db.Decimal(10, 2)

  sortOrder Int   @default(0)
  metadata  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([estimateId])
  @@index([serviceCatalogItemId])
  @@index([category])
  @@index([sortOrder])
  @@map("estimate_items")
}

model Quote {
  id          String @id @default(uuid()) @db.Uuid
  quoteNumber String @unique

  customerId String   @db.Uuid
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)

  orderId String? @db.Uuid
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  sessionId String?  @db.Uuid
  session   Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  status QuoteStatus @default(DRAFT)

  subtotal  Decimal @default(0) @db.Decimal(10, 2)
  taxRate   Decimal @default(0) @db.Decimal(5, 2)
  taxAmount Decimal @default(0) @db.Decimal(10, 2)
  total     Decimal @default(0) @db.Decimal(10, 2)
  currency  String  @default("CHF")

  items Json?
  notes String?

  validUntil DateTime?
  sentAt     DateTime?
  acceptedAt DateTime?

  invoice          Invoice?
  attachments      Attachment[]
  publicOfferLinks PublicOfferLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([orderId])
  @@index([sessionId])
  @@index([status])
  @@map("quotes")
}

model PublicOfferLink {
  id String @id @default(uuid()) @db.Uuid

  tokenHash   String  @unique
  tokenPrefix String?

  quoteId String @db.Uuid
  quote   Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  customerId String   @db.Uuid
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)

  expiresAt    DateTime
  acceptedAt   DateTime?
  revokedAt    DateTime?
  lastViewedAt DateTime?
  viewCount    Int       @default(0)

  createdBy String?
  metadata  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([quoteId])
  @@index([customerId])
  @@index([expiresAt])
  @@index([acceptedAt])
  @@index([revokedAt])
  @@map("public_offer_links")
}

model Invoice {
  id            String @id @default(uuid()) @db.Uuid
  invoiceNumber String @unique

  customerId String   @db.Uuid
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)

  orderId String? @db.Uuid
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  quoteId String? @unique @db.Uuid
  quote   Quote?  @relation(fields: [quoteId], references: [id], onDelete: SetNull)

  status InvoiceStatus @default(DRAFT)

  issueDate DateTime  @default(now())
  dueDate   DateTime?

  subtotal   Decimal @default(0) @db.Decimal(10, 2)
  taxRate    Decimal @default(0) @db.Decimal(5, 2)
  taxAmount  Decimal @default(0) @db.Decimal(10, 2)
  total      Decimal @default(0) @db.Decimal(10, 2)
  paidAmount Decimal @default(0) @db.Decimal(10, 2)
  currency   String  @default("CHF")

  pdfUrl String?
  notes  String?

  sentAt DateTime?
  paidAt DateTime?

  items       InvoiceItem[]
  payments    Payment[]
  attachments Attachment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([orderId])
  @@index([status])
  @@index([issueDate])
  @@map("invoices")
}

model InvoiceItem {
  id String @id @default(uuid()) @db.Uuid

  invoiceId String  @db.Uuid
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  serviceCatalogItemId String?             @db.Uuid
  serviceCatalogItem   ServiceCatalogItem? @relation(fields: [serviceCatalogItemId], references: [id], onDelete: SetNull)

  name        String
  description String?

  category ServiceCatalogCategory?
  unit     ServiceCatalogUnit      @default(FLAT)

  quantity  Decimal @default(1.00) @db.Decimal(10, 2)
  unitPrice Decimal @default(0) @db.Decimal(10, 2)
  subtotal  Decimal @default(0) @db.Decimal(10, 2)

  taxRate   Decimal @default(0) @db.Decimal(5, 2)
  taxAmount Decimal @default(0) @db.Decimal(10, 2)

  discountAmount Decimal @default(0) @db.Decimal(10, 2)
  total          Decimal @default(0) @db.Decimal(10, 2)

  sortOrder Int   @default(0)
  metadata  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([invoiceId])
  @@index([serviceCatalogItemId])
  @@index([category])
  @@index([sortOrder])
  @@map("invoice_items")
}

model Payment {
  id String @id @default(uuid()) @db.Uuid

  invoiceId String?  @db.Uuid
  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  orderId String? @db.Uuid
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  amount   Decimal @db.Decimal(10, 2)
  currency String  @default("CHF")

  status PaymentStatus @default(PENDING)
  method PaymentMethod @default(BANK_TRANSFER)

  externalRef String?
  notes       String?

  paidAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([invoiceId])
  @@index([orderId])
  @@index([status])
  @@map("payments")
}

model Notification {
  id String @id @default(uuid()) @db.Uuid

  customerId String?   @db.Uuid
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  orderId String? @db.Uuid
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  estimateId String?   @db.Uuid
  estimate   Estimate? @relation(fields: [estimateId], references: [id], onDelete: SetNull)

  sessionId String?  @db.Uuid
  session   Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  channel NotificationChannel
  status  NotificationStatus  @default(PENDING)

  recipient String
  subject   String?
  message   String

  errorMessage String?
  metadata     Json?

  sentAt DateTime?
  readAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([orderId])
  @@index([estimateId])
  @@index([sessionId])
  @@index([status])
  @@index([channel])
  @@map("notifications")
}

model Attachment {
  id String @id @default(uuid()) @db.Uuid

  customerId String?   @db.Uuid
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  orderId String? @db.Uuid
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  estimateId String?   @db.Uuid
  estimate   Estimate? @relation(fields: [estimateId], references: [id], onDelete: SetNull)

  sessionId String?  @db.Uuid
  session   Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  quoteId String? @db.Uuid
  quote   Quote?  @relation(fields: [quoteId], references: [id], onDelete: SetNull)

  invoiceId String?  @db.Uuid
  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  type AttachmentType @default(OTHER)

  fileName  String
  mimeType  String?
  url       String
  sizeBytes Int?

  uploadedBy String?
  metadata   Json?

  createdAt DateTime @default(now())

  @@index([customerId])
  @@index([orderId])
  @@index([estimateId])
  @@index([sessionId])
  @@index([quoteId])
  @@index([invoiceId])
  @@map("attachments")
}

model AuditLog {
  id String @id @default(uuid()) @db.Uuid

  customerId String?   @db.Uuid
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  orderId String? @db.Uuid
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  estimateId String?   @db.Uuid
  estimate   Estimate? @relation(fields: [estimateId], references: [id], onDelete: SetNull)

  sessionId String?  @db.Uuid
  session   Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  action     AuditAction
  entityType String
  entityId   String?

  actorType String  @default("system")
  actorId   String?

  before    Json?
  after     Json?
  message   String?
  ipAddress String?
  metadata  Json?

  createdAt DateTime @default(now())

  @@index([customerId])
  @@index([orderId])
  @@index([estimateId])
  @@index([sessionId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
  @@map("audit_logs")
}

model PublicSecurityEvent {
  id String @id @default(uuid()) @db.Uuid

  scope    String
  reason   String
  severity String @default("warning")

  ipHash          String?
  fingerprintHash String?
  userAgentHash   String?
  tokenPrefix     String?

  path   String?
  method String?

  extra Json?

  createdAt DateTime @default(now())

  @@index([scope])
  @@index([reason])
  @@index([severity])
  @@index([createdAt])
  @@index([scope, createdAt])
  @@index([severity, createdAt])
  @@index([fingerprintHash, createdAt])
  @@index([tokenPrefix])
  @@map("public_security_events")
}

model PublicAccessLog {
  id String @id @default(uuid()) @db.Uuid

  scope  String
  path   String?
  method String?

  statusCode Int?
  success    Boolean @default(false)

  ipHash          String?
  fingerprintHash String?
  userAgentHash   String?
  tokenPrefix     String?

  rateLimitKey       String?
  rateLimitAllowed   Boolean?
  rateLimitRemaining Int?
  retryAfterSeconds  Int?

  requestBytes Int?
  responseMs   Int?

  extra Json?

  createdAt DateTime @default(now())

  @@index([scope])
  @@index([path])
  @@index([statusCode])
  @@index([success])
  @@index([createdAt])
  @@index([scope, createdAt])
  @@index([fingerprintHash, createdAt])
  @@index([tokenPrefix])
  @@map("public_access_logs")
}

model ServiceCatalogItem {
  id String @id @default(uuid()) @db.Uuid

  tenantKey String @default("hexa-clean")

  name        String
  slug        String
  description String?

  category ServiceCatalogCategory
  unit     ServiceCatalogUnit     @default(FLAT)

  basePrice Decimal  @default(0) @db.Decimal(10, 2)
  minPrice  Decimal  @default(0) @db.Decimal(10, 2)
  maxPrice  Decimal? @db.Decimal(10, 2)

  defaultQuantity Decimal? @db.Decimal(10, 2)
  riskMultiplier  Decimal  @default(1.00) @db.Decimal(5, 2)

  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  notes    String?
  metadata Json?

  estimateItems EstimateItem[]
  invoiceItems  InvoiceItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantKey, slug])
  @@index([tenantKey])
  @@index([category])
  @@index([isActive])
  @@index([sortOrder])
  @@map("service_catalog_items")
}
