generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum CustomerType {
  PRIVATE
  COMPANY
}

enum SessionStatus {
  ACTIVE
  COMPLETED
  ABANDONED
  EXPIRED
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
  OWNER
}

enum ServiceType {
  REINIGUNG
  HAUSWARTUNG
  KLEINREPARATUREN
  UMZUGSREINIGUNG
  FENSTERREINIGUNG
  WOHNUNGSABGABE
  OTHER
}

enum OrderStatus {
  NEW
  IN_PROGRESS
  WAITING_FOR_CUSTOMER
  CONFIRMED
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELLED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  TWINT
  CARD
  OTHER
}

enum NotificationChannel {
  EMAIL
  WHATSAPP
  SMS
  PUSH
  SYSTEM
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

enum AttachmentType {
  PHOTO
  DOCUMENT
  INVOICE
  QUOTE
  OTHER
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  SYSTEM
  AI
}

model Customer {
  id   String       @id @default(uuid()) @db.Uuid
  type CustomerType @default(PRIVATE)

  firstName   String?
  lastName    String?
  companyName String?

  email String?
  phone String?

  street  String?
  zipCode String?
  city    String?
  country String  @default("CH")

  notes String?

  sessions      Session[]
  messages      ConversationMessage[]
  orders        Order[]
  quotes        Quote[]
  invoices      Invoice[]
  notifications Notification[]
  attachments   Attachment[]
  auditLogs     AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([phone])
  @@index([city])
  @@map("customers")
}

model Session {
  id     String        @id @default(uuid()) @db.Uuid
  status SessionStatus @default(ACTIVE)

  customerId String?   @db.Uuid
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  source   String?
  metadata Json?

  messages      ConversationMessage[]
  orders        Order[]
  quotes        Quote[]
  notifications Notification[]
  attachments   Attachment[]
  auditLogs     AuditLog[]

  startedAt DateTime  @default(now())
  endedAt   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([startedAt])
  @@map("sessions")
}

model ConversationMessage {
  id String @id @default(uuid()) @db.Uuid

  sessionId String  @db.Uuid
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  customerId String?   @db.Uuid
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  role     MessageRole
  content  String
  metadata Json?

  createdAt DateTime @default(now())

  @@index([sessionId, createdAt])
  @@index([customerId])
  @@map("conversation_messages")
}

model Order {
  id          String @id @default(uuid()) @db.Uuid
  orderNumber String @unique

  customerId String   @db.Uuid
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)

  sessionId String?  @db.Uuid
  session   Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  serviceType ServiceType
  title       String?
  description String?

  status OrderStatus @default(NEW)

  estimatedPrice Decimal? @db.Decimal(10, 2)
  finalPrice     Decimal? @db.Decimal(10, 2)
  currency       String   @default("CHF")

  serviceStreet  String?
  serviceZipCode String?
  serviceCity    String?
  serviceCountry String? @default("CH")

  preferredDate  DateTime?
  scheduledStart DateTime?
  scheduledEnd   DateTime?

  notesCustomer String?
  notesInternal String?

  quotes        Quote[]
  invoices      Invoice[]
  payments      Payment[]
  notifications Notification[]
  attachments   Attachment[]
  auditLogs     AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([sessionId])
  @@index([status])
  @@index([serviceType])
  @@index([scheduledStart])
  @@map("orders")
}

model Quote {
  id          String @id @default(uuid()) @db.Uuid
  quoteNumber String @unique

  customerId String   @db.Uuid
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)

  orderId String? @db.Uuid
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  sessionId String?  @db.Uuid
  session   Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  status QuoteStatus @default(DRAFT)

  subtotal  Decimal @default(0) @db.Decimal(10, 2)
  taxRate   Decimal @default(0) @db.Decimal(5, 2)
  taxAmount Decimal @default(0) @db.Decimal(10, 2)
  total     Decimal @default(0) @db.Decimal(10, 2)
  currency  String  @default("CHF")

  items Json?
  notes String?

  validUntil DateTime?
  sentAt     DateTime?
  acceptedAt DateTime?

  invoice     Invoice?
  attachments Attachment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([orderId])
  @@index([sessionId])
  @@index([status])
  @@map("quotes")
}

model Invoice {
  id            String @id @default(uuid()) @db.Uuid
  invoiceNumber String @unique

  customerId String   @db.Uuid
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)

  orderId String? @db.Uuid
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  quoteId String? @unique @db.Uuid
  quote   Quote?  @relation(fields: [quoteId], references: [id], onDelete: SetNull)

  status InvoiceStatus @default(DRAFT)

  issueDate DateTime  @default(now())
  dueDate   DateTime?

  subtotal   Decimal @default(0) @db.Decimal(10, 2)
  taxRate    Decimal @default(0) @db.Decimal(5, 2)
  taxAmount  Decimal @default(0) @db.Decimal(10, 2)
  total      Decimal @default(0) @db.Decimal(10, 2)
  paidAmount Decimal @default(0) @db.Decimal(10, 2)
  currency   String  @default("CHF")

  pdfUrl String?
  notes  String?

  sentAt DateTime?
  paidAt DateTime?

  payments    Payment[]
  attachments Attachment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([orderId])
  @@index([status])
  @@index([issueDate])
  @@map("invoices")
}

model Payment {
  id String @id @default(uuid()) @db.Uuid

  invoiceId String?  @db.Uuid
  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  orderId String? @db.Uuid
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  amount   Decimal @db.Decimal(10, 2)
  currency String  @default("CHF")

  status PaymentStatus @default(PENDING)
  method PaymentMethod @default(BANK_TRANSFER)

  externalRef String?
  notes       String?

  paidAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([invoiceId])
  @@index([orderId])
  @@index([status])
  @@map("payments")
}

model Notification {
  id String @id @default(uuid()) @db.Uuid

  customerId String?   @db.Uuid
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  orderId String? @db.Uuid
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  sessionId String?  @db.Uuid
  session   Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  channel NotificationChannel
  status  NotificationStatus  @default(PENDING)

  recipient String
  subject   String?
  message   String

  errorMessage String?
  metadata     Json?

  sentAt DateTime?
  readAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([orderId])
  @@index([sessionId])
  @@index([status])
  @@index([channel])
  @@map("notifications")
}

model Attachment {
  id String @id @default(uuid()) @db.Uuid

  customerId String?   @db.Uuid
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  orderId String? @db.Uuid
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  sessionId String?  @db.Uuid
  session   Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  quoteId String? @db.Uuid
  quote   Quote?  @relation(fields: [quoteId], references: [id], onDelete: SetNull)

  invoiceId String?  @db.Uuid
  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  type AttachmentType @default(OTHER)

  fileName  String
  mimeType  String?
  url       String
  sizeBytes Int?

  uploadedBy String?
  metadata   Json?

  createdAt DateTime @default(now())

  @@index([customerId])
  @@index([orderId])
  @@index([sessionId])
  @@index([quoteId])
  @@index([invoiceId])
  @@map("attachments")
}

model AuditLog {
  id String @id @default(uuid()) @db.Uuid

  customerId String?   @db.Uuid
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  orderId String? @db.Uuid
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  sessionId String?  @db.Uuid
  session   Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  action     AuditAction
  entityType String
  entityId   String?

  actorType String  @default("system")
  actorId   String?

  before    Json?
  after     Json?
  message   String?
  ipAddress String?
  metadata  Json?

  createdAt DateTime @default(now())

  @@index([customerId])
  @@index([orderId])
  @@index([sessionId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
  @@map("audit_logs")
}
